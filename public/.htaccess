<IfModule mod_rewrite.c>
    RewriteEngine On

    # إذا كان الملف أو المجلد موجوداً بالفعل، اسمح بفتحه مباشرة وعدم توجيهه للنظام
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # توجيه باقي الطلبات إلى نقطة الدخول الرئيسية (تأكدي ما إذا كانت index.php أو router.php حسب هيكلك)
    RewriteRule ^(.*)$ index.php?page=$1 [QSA,L]
</IfModule>
